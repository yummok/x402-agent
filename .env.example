# ═══════════════════════════════════════════════════════════════
# x402 Agent — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# NEVER commit your .env file — it is gitignored by default.
# ═══════════════════════════════════════════════════════════════

# ── Coinbase Developer Platform (CDP) ──────────────────────────
# Required for mainnet x402 payment verification and settlement.
# Get your credentials at: https://portal.cdp.coinbase.com/
CDP_API_KEY_ID=your_cdp_api_key_id_here
CDP_API_KEY_SECRET=your_cdp_api_secret_here

# ── Agent Wallet ──────────────────────────────────────────────
# Ethereum private key for signing EIP-3009 USDC transfers.
# Generate with: npx viem generate-private-key
# Fund with USDC on Base mainnet before use.
# ⚠️ NEVER share or commit this key!
X402_WALLET_PRIVATE_KEY=0x_your_private_key_here

# ── Optional: GitHub (for automation scripts) ──────────────────
# Classic token with repo scope for repository operations.
# GITHUB_TOKEN=ghp_your_github_token_here
