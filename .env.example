# Environment variables — copy to .env and fill in your values
# NEVER commit your .env file!

# Coinbase Developer Platform (CDP) API credentials
# Get them at https://portal.cdp.coinbase.com/
CDP_API_KEY_ID=your_cdp_api_key_id_here
CDP_API_KEY_SECRET=your_cdp_api_key_secret_here

# Agent wallet private key (for signing EIP-3009 payments)
# Generate with: npx viem generate-private-key
X402_WALLET_PRIVATE_KEY=0x_your_private_key_here
